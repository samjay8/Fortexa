# =============================================================================
# Fortexa — Local Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values you need:
#
#   cp .env.example .env.local
#
# All values shown below are safe placeholders. None are real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Stellar Network
# ---------------------------------------------------------------------------
# Horizon API endpoint (testnet is the safe default for local development).
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase — must match the network served by STELLAR_HORIZON_URL.
# Leave empty to auto-detect from the Horizon URL.
STELLAR_NETWORK_PASSPHRASE=

# Payment quote TTL: seconds after an APPROVE/WARN decision before
# /api/stellar/build-payment rejects the quote (default 300).
FORTEXA_PAYMENT_QUOTE_TTL_SECONDS=300

# Optional UI default for payment destination
NEXT_PUBLIC_STELLAR_DESTINATION=

# ---------------------------------------------------------------------------
# Auth (Wallet Login & Session)
# ---------------------------------------------------------------------------
# Secret key used to sign session cookies (HMAC). Generate a long random
# string for local dev, e.g.: openssl rand -hex 32
FORTEXA_AUTH_SECRET=dev-unsafe-secret-change-me

# Comma-separated list of Stellar public keys (G…) allowed as operators.
# Leave empty to grant operator role to any valid wallet (dev only).
FORTEXA_OPERATOR_WALLETS=

# Comma-separated list of Stellar public keys (G…) allowed as viewers.
# Leave empty to grant viewer role to any valid wallet (dev only).
FORTEXA_VIEWER_WALLETS=

# TTL (seconds) for one-time login challenges. Default: 300 (5 minutes).
FORTEXA_AUTH_CHALLENGE_TTL_SECONDS=300

# Maximum failed login attempts before wallet is locked. Default: 5.
FORTEXA_AUTH_MAX_ATTEMPTS=5

# Lockout duration (minutes) after exceeding max attempts. Default: 10.
FORTEXA_AUTH_LOCK_MINUTES=10

# ---------------------------------------------------------------------------
# Storage & Persistence
# ---------------------------------------------------------------------------
# Postgres connection string. When set, Fortexa uses PostgreSQL for all
# stores (audit, policy, wallet, idempotency). Leave empty for local
# JSON-file fallback under .fortexa/ (or /tmp/fortexa/ on Vercel).
DATABASE_URL=

# Enable SSL for the Postgres connection (set to "true" if required).
DATABASE_SSL=false

# Override the directory used for file-based storage (when DATABASE_URL
# is not set). Defaults to .fortexa/ locally or /tmp/fortexa/ on Vercel.
FORTEXA_STORE_DIR=

# ---------------------------------------------------------------------------
# Shared State (Rate Limiting, Brute-Force Lockout)
# ---------------------------------------------------------------------------
# File path for shared security state (lockouts, rate limits).
# Use an absolute path on Vercel (e.g., /tmp/fortexa/shared-security-state.json).
FORTEXA_SHARED_STATE_PATH=

# Redis URL for distributed state in multi-instance deployments.
# When set, Redis is used for shared state; falls back to file store
# if Redis is unreachable or unconfigured.
REDIS_URL=

# ---------------------------------------------------------------------------
# Idempotency
# ---------------------------------------------------------------------------
# Number of days to retain idempotency records for signed XDR submissions.
# Defaults to 7 if not set.
FORTEXA_IDEMPOTENCY_RETENTION_DAYS=7

# ---------------------------------------------------------------------------
# Optional Integrations
# ---------------------------------------------------------------------------
# Groq AI API key — enables the /api/agent/plan endpoint for AI-assisted
# action planning. Leave empty to disable the Groq integration.
GROQ_API_KEY=

# Groq model to use. Default: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# External blocklist URL for dynamic threat intelligence.
# Accepts a JSON array of domains or plain text (one domain per line,
# # comments ignored). Cached in-memory for 5 minutes; feed failures
# fall back silently. Leave empty to disable.
FORTEXA_BLOCKLIST_URL=

# ---------------------------------------------------------------------------
# Request Handling
# ---------------------------------------------------------------------------
# Maximum JSON request body size in bytes. Default: 65536 (64 KiB).
FORTEXA_JSON_BODY_MAX_BYTES=65536

# ---------------------------------------------------------------------------
# Local Development Utilities
# ---------------------------------------------------------------------------
# Set to "true" to allow the local demo state reset script to run.
# Must also pass --yes flag to the script. Only works against localhost DBs.
FORTEXA_ALLOW_LOCAL_RESET=false
